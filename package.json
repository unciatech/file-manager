{
  "name": "@unciatech/file-manager",
  "version": "0.0.45",
  "description": "Modern file manager component for React applications",
  "author": "Avi",
  "license": "MIT",
  "homepage": "https://github.com/unciatech/file-manager",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unciatech/file-manager.git"
  },
  "keywords": [
    "file-manager",
    "react-file-manager",
    "nextjs-file-manager",
    "file-browser",
    "react-component",
    "unciatech"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js",
      "require": "./dist/mock.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup && cp styles.css dist/styles.css && echo 'declare const styles: any; export default styles;' > dist/styles.d.ts",
    "clean": "rm -rf dist .next",
    "prepublish": "npm run build:pkg",
    "release": "npm run build:pkg && npm publish",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "mime": "^4.1.0",
    "radix-ui": "^1.4.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "@radix-ui/react-context-menu": "^2",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-tooltip": "^1",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "latest",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}