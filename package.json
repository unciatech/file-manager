{
  "name": "@unciatech/file-manager",
  "version": "0.0.23",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "file-manager": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.mjs",
      "require": "./dist/mock.js",
      "default": "./dist/mock.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "author": "Avi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unciatech/file-manager.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup && cp styles.css dist/styles.css",
    "clean": "rm -rf dist .next",
    "prepublishOnly": "npm run build:pkg",
    "release": "npm run build:pkg && npm publish",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "mime": "^4.1.0",
    "radix-ui": "^1.4.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "latest",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
